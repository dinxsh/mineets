# Server-only TxLINE envs. Do not prefix JWT/API token with VITE_.
# Use one network consistently for wallet, program, guest JWT, and API token.
# mainnet: free World Cup service level 1 delayed, 12 real-time.
# devnet: host/program/token mint differ; current free row is service level 1.
TXLINE_NETWORK=mainnet
TXLINE_ORIGIN=https://txline.txodds.com

# TxLINE requires both a guest JWT and an activated API token.
# Guest JWT comes from POST https://txline.txodds.com/auth/guest/start
# API token comes from POST https://txline.txodds.com/api/token/activate
TXLINE_JWT=replace_with_guest_jwt
TXLINE_API_TOKEN=replace_with_activated_api_token
TXLINE_SERVICE_LEVEL=12

# Optional: pin the demo to one fixture. If omitted, the app uses fixtures snapshot.
TXLINE_FIXTURE_ID=replace_with_fixture_id

# Optional client fallback if you want to demo with World Cup API-shaped live scores.
VITE_WORLDCUP_API_KEY=replace_with_worldcupapi_key
